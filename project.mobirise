              },
              ".mbr-text": {
                "margin-bottom": "40px",
                "@media (max-width: 768px)": {
                  "margin-bottom": "20px"
                }
              }
            },
            ".video-block": {
              ".video-wrapper": {
                "iframe": {
                  "border-radius": "16px"
                },
                ".app-video-wrapper": {
                  "img": {
                    "height": "320px",
                    "object-fit": "cover",
                    "border-radius": "16px"
                  },
                  "&::before": {
                    "display": "flex",
                    "align-items": "center",
                    "justify-content": "center",
                    "height": "82px",
                    "width": "82px",
                    "color": "@play",
                    "background-color": "@playBg",
                    "text-shadow": "none",
                    "font-size": "20px",
                    "border-radius": "100%",
                    "top": "auto",
                    "bottom": "20px",
                    "left": "60px"
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#08323C"
            },
            ".mbr-desc": {
              "color": "#08323C"
            },
            ".mbr-text": {
              "color": "#08323C"
            }
          },
